* {
    background-color: #1e1e2e;
    text-color: #cdd6f4;
    border-color: #89b4fa;
}

window {
    border: 2px;
    padding: 10px;
}

inputbar {
    children: [prompt, entry];
    background-color: #313244;
    border-radius: 5px;
    padding: 8px;
}

listview {
    lines: 10;
}

element {
    padding: 8px;
    border-radius: 5px;
}

element selected {
    background-color: #89b4fa;
    text-color: #1e1e2e;
}
