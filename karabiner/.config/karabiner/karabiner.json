/*
CHANGE IN MACOS SETTINGS - KEYBOARD - KEYBOARD SHORTCUTS
- spotlight search (DISABLE)
- input sources - select the previous input source (CMD SHIFT CTRL ALT SPACE)
- screenshots - everyhing same shortcuts but option instead of command
WHEN ADDING NEW RULE REMEMBER TO EXCLUDE MOONLIGHT FROM IT!!!
*/

{
  "profiles": [
    {
      "complex_modifications": {
        "rules": [
          // GENERAL REMAPS
          // Command keys to Control + tracking
          {
            "description": "Map Command keys to Control and Track left and right command held state",
            "manipulators": [
              {
                "type": "basic",
                "from": { "key_code": "left_command", "modifiers": { "optional": ["any"] } },
                "to": [
                  { "set_variable": { "name": "physical_left_cmd_held", "value": 1 } },
                  { "key_code": "left_control" }
                ],
                "to_after_key_up": [
                  { "set_variable": { "name": "physical_left_cmd_held", "value": 0 } }
                ],
                "conditions": [
                  { "type": "frontmost_application_unless", "bundle_identifiers": ["com.moonlight-stream.Moonlight"] }
                ]
              },
              {
                "type": "basic",
                "from": { "key_code": "right_command", "modifiers": { "optional": ["any"] } },
                "to": [
                  { "set_variable": { "name": "physical_right_cmd_held", "value": 1 } },
                  { "key_code": "left_control" }
                ],
                "to_after_key_up": [
                  { "set_variable": { "name": "physical_right_cmd_held", "value": 0 } }
                ],
                "conditions": [
                  { "type": "frontmost_application_unless", "bundle_identifiers": ["com.moonlight-stream.Moonlight"] }
                ]
              }
            ]
          },
          // Caps Lock to Escape on tap and Control on hold
          {
            "description": "Caps Lock to Escape on tap and Control on hold",
            "manipulators": [
              {
                "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
                "to": [{ "key_code": "left_control" }],
                "to_if_alone": [{ "key_code": "escape" }],
                "type": "basic"
              }
            ]
          },
          // USEFUL CONTROL + SOMETHING GLOBAL SHORTCUTS
          {
            "description": "Map ctrl+something to other keys",
            "manipulators": [
              // ctrl + ? for backspace
              {
                "from": { "key_code": "period", "modifiers": { "mandatory": ["control"] } },
                "to": [{ "key_code": "delete_or_backspace" }],
                "type": "basic"
              },
              // ctrl + m for enter
              {
                "from": { "key_code": "m", "modifiers": { "mandatory": ["control"] } },
                "to": [{ "key_code": "return_or_enter" }],
                "type": "basic"
              }
            ]
          },
          // GHOSTTY REMAPS
          {
            "description": "Ghostty: control+shift+c/v - copy/paste",
            "manipulators": [
              {
                "type": "basic",
                "from": {
                  "key_code": "c",
                  "modifiers": { "mandatory": ["control", "shift"] }
                },
                "to": [{
                  "key_code": "c",
                  "modifiers": ["command"]
                }],
                "conditions": [{
                  "type": "frontmost_application_if",
                  "bundle_identifiers": ["com.mitchellh.ghostty"]
                }]
              },
              {
                "type": "basic",
                "from": {
                  "key_code": "v",
                  "modifiers": { "mandatory": ["control", "shift"] }
                },
                "to": [{
                  "key_code": "v",
                  "modifiers": ["command"]
                }],
                "conditions": [{
                  "type": "frontmost_application_if",
                  "bundle_identifiers": ["com.mitchellh.ghostty"]
                }]
              }
            ]
          },
          {
            "description": "Ghostty: Missing imporant keybinds that don't work as we don't swap control to command",
            "manipulators": [
              // Command + W to Command + Q for both left and right Command
              {
                "type": "basic",
                "from": {
                  "key_code": "w",
                  "modifiers": { "mandatory": ["control"] }
                },
                "to": [{
                  "key_code": "q",
                  "modifiers": ["command"]
                }],
                "conditions": [
