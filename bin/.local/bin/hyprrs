#!/bin/bash

# hyprrs - Hyprland(hypr) Reload(r) Service(s)

# Check if service name was provided
if [ -z "$1" ]; then
    echo "Usage: hyprrs <service-name>"
    echo "Example: hyprrs waybar"
    exit 1
fi

service_name="$1"
full_run_command="$@"

# Kill the service
pkill "$service_name"

# Wait a short moment for it to die
sleep 0.1

# Restart with hyprctl
hyprctl dispatch exec "$full_run_command"

echo "Reloaded: $service_name"
